# ==========================================
# 创新创业服务系统 - 环境变量配置
# 复制此文件为 .env 并修改对应值
# ==========================================
#
# 【CAS SSL 证书配置】
# 如果 CAS 服务器使用自签名证书，需要将证书导入容器：
#
# 步骤1: 获取证书
#   ./fetch-cas-cert.sh ids.wisedu.com.cn 9086
#
# 步骤2: 启动时容器会自动导入 certs 目录下的证书
#
# 步骤3: 如果证书有更新，重启容器即可重新导入
#

# ------------------------------------------
# 数据库配置
# ------------------------------------------
MYSQL_ROOT_PASSWORD=your_db_password
MYSQL_USER=root

# ------------------------------------------
# JWT配置
# ------------------------------------------
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=86400000

# ------------------------------------------
# GitHub配置（用于镜像拉取）
# ------------------------------------------
GITHUB_OWNER=your-github-username

# ==========================================
# CAS统一身份认证配置（关键配置）
# ==========================================

# 是否启用CAS登录（true/false）
CAS_ENABLED=true

# 是否为Mock模式（本地测试用，无需真实CAS服务器）
CAS_MOCK_MODE=false

# CAS服务器地址前缀（通常是https，如果证书有问题可以临时用http测试）
CAS_SERVER_URL_PREFIX=https://ids.wisedu.com.cn:9086/authserver

# CAS登录页面URL
CAS_SERVER_LOGIN_URL=https://ids.wisedu.com.cn:9086/authserver/login

# 本应用后端地址（CAS回调用，必须带 /api 后缀！）
# 注意：这里必须配置带 /api 的地址，如 https://your-domain.com/api
# 因为 Nginx 只会把 /api/ 开头的请求代理到后端
# 系统会自动从这个地址推导出前端地址
CAS_CLIENT_HOST_URL=https://your-domain.com/api

# 是否忽略SSL证书验证（仅用于测试环境！生产环境请设置为false并配置正确证书）
CAS_IGNORE_SSL_VALIDATION=false

# CAS服务器IP白名单校验（可选）
# 默认关闭（false），内网环境可不配置CAS服务器IP
# 如需开启，设为true并配置 CAS_SERVER_IPS
CAS_IP_WHITELIST_ENABLED=false

# CAS服务器IP白名单（逗号分隔），开启白名单校验时必填
# 示例：CAS_SERVER_IPS=10.0.0.1,10.0.0.2
CAS_SERVER_IPS=

# ------------------------------------------
# SMTP邮件配置（可选）
# 启用后，有新的审批时会自动邮件提醒管理员和申请人
# ------------------------------------------
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-password
